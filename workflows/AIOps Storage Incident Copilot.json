      "parameters": {
        "jsCode": "const matches = $json.matches;\n\nconst formatted = matches.map((m, index) => {\n  return `\nMATCH ${index + 1}\n\nSimilarity Score: ${m.score}\n\nHistorical Incident:\n${m.metadata.text}\n`;\n}).join(\"\\n-------------------\\n\");\n\nreturn [\n  {\n    json: {\n      historical_context: formatted\n    }\n  }\n];"
