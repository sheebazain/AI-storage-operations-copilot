        "body": "={{\nJSON.stringify({\n  contents: [\n    {\n      parts: [\n        {\n          text: `\nYou are an enterprise Dell EMC AI Operations Engineer.\n\nAnalyze the current infrastructure incident.\n\nUse the historical incidents to:\n- identify probable root cause\n- estimate confidence\n- recommend remediation\n- identify business impact\n- suggest escalation priority\n\nCURRENT INCIDENT:\n${JSON.stringify($('Parse AI Analysis').item.json)}\n\nHISTORICAL INCIDENTS:\n${$json.historical_context}\n\nReturn STRICT JSON:\n\n{\n  \"probable_root_cause\": \"\",\n  \"confidence_score\": \"\",\n  \"recommended_actions\": [],\n  \"business_impact\": \"\",\n  \"escalation_priority\": \"\",\n  \"preventive_measures\": []\n}\n`\n        }\n      ]\n    }\n  ]\n})\n}}",
