    {
      "parameters": {
        "jsCode": "let raw =\n$json.candidates[0]\n.content.parts[0]\n.text;\n\n// Remove markdown code blocks\nraw = raw.replace(/```json/g, '');\nraw = raw.replace(/```/g, '');\n\n// Trim spaces/newlines\nraw = raw.trim();\n\nreturn [{\n  json: JSON.parse(raw)\n}];"
      },
