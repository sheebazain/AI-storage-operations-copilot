    {
      "parameters": {
        "jsCode": "const d = $json;\n\nconst report = `\n# AI OPERATIONS INCIDENT REPORT\n\n## INCIDENT SUMMARY\n${d.business_impact}\n\n---\n\n## PROBABLE ROOT CAUSE\n${d.probable_root_cause}\n\n---\n\n## AI CONFIDENCE\n🧠 ${Math.round(d.confidence_score * 100)}%\n\n---\n\n## ESCALATION PRIORITY\n🔴 ${d.escalation_priority}\n\n---\n\n## RECOMMENDED ACTIONS\n${d.recommended_actions.map(a => `- ${a}`).join('\\n')}\n\n---\n\n## PREVENTIVE MEASURES\n${d.preventive_measures.map(a => `- ${a}`).join('\\n')}\n\n---\n\nGenerated by:\nAI Storage Operations Copilot\n`;\n\nreturn [\n  {\n    json: {\n      text: report\n    }\n  }\n];"
      },
