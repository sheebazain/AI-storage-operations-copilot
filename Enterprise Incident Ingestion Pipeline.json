      "name": "Embeddings"
    },
    {
      "parameters": {
        "jsCode": "const incident = $json;\n\nconst document = `\nINCIDENT ID: ${incident.incident_id}\n\nSEVERITY: ${incident.severity}\n\nCOMPONENT: ${incident.component}\n\nSYMPTOM:\n${incident.symptom}\n\nLOGS:\n${incident.logs.join(\"\\n\")}\n\nROOT CAUSE:\n${incident.root_cause}\n\nRESOLUTION:\n${incident.resolution.join(\"\\n\")}\n\nBUSINESS IMPACT:\n${incident.business_impact}\n`;\n\nreturn [{\n  json: {\n    document\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ],
      "id": "e0275689-a256-4c95-b16b-6751bedd0aca",
      "name": "Create Incident Document"
