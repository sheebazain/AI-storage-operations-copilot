      ],
      "id": "a6a0a54d-5fb7-403e-9c11-7ee2181f8259",
      "name": "Extract from File"
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.text;\n\nconst incidents = JSON.parse(raw);\n\nreturn incidents.map(i => ({\n  json: i\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        432,
        0
      ],
      "id": "b9f56fff-eba8-4564-88bd-a06fd8f16aa1",
      "name": "Parse Incidents"
    },
    {
      "parameters": {
        "jsCode": "const text = $json.document;\n\nconst chunkSize = 800;\n\nconst chunks = [];\n\nfor (let i = 0; i < text.length; i += chunkSize) {\n\n  chunks.push({\n    chunk: text.slice(i, i + chunkSize)\n  });\n\n}\n\nreturn chunks.map(c => ({\n  json: c\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        0
      ],
      "id": "07b15c64-4c2c-4b5b-91af-535873ac1067",
      "name": "Chunk Incident"
    },
    {
      "parameters": {
        "jsCode": "const chunk =\n$('Chunk Incident').first().json.chunk;\n\nconst incidentId =\n$('Parse Incidents').first().json.incident_id || 'unknown';\n\nreturn [{\n  json: {\n    vectors: [\n      {\n        id: `${incidentId}_${Date.now()}`,\n\n        values: $json.embedding.values,\n\n        metadata: {\n          text: chunk\n        }\n      }\n    ]\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1488,
        0
      ],
